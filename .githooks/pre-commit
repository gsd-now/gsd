#!/bin/bash
# Pre-commit hook: runs fmt, check, clippy, test, and udeps

set -e

echo "Running cargo fmt..."
cargo fmt --all
git add -u  # Re-stage any files that were reformatted

echo "Running cargo check..."
cargo check --workspace --all-targets

echo "Running cargo clippy..."
cargo clippy --workspace --all-targets -- -D warnings

echo "Running cargo test..."
cargo test --workspace -- --test-threads=1

echo "Running cargo udeps (requires nightly)..."
if rustup run nightly cargo udeps --help > /dev/null 2>&1; then
    cargo +nightly udeps --workspace --all-targets
else
    echo "Warning: cargo-udeps not installed or nightly not available, skipping"
fi

echo "Pre-commit checks passed!"
