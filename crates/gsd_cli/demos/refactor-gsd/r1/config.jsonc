// Example invocation:
// pnpm gsd run --pool <POOL> --initial '[{"kind": "ListFiles", "value": {"folder": "./src"}}]' config.jsonc
//
// NOTE: This workflow is not included in run-all-demos.sh because it requires
// a real codebase and Claude agents to function.
{
  "options": {
    "max_retries": 2
  },
  "steps": [
    {
      "name": "ListFiles",
      "value_schema": {
        "type": "object",
        "required": ["folder"],
        "properties": {
          "folder": {
            "type": "string",
            "description": "Path to folder to scan for files"
          }
        },
        "additionalProperties": false
      },
      "action": {
        "kind": "Pool",
        "instructions": {"link": "list-files.md"}
      },
      "next": ["AnalyzeFile"]
    },
    {
      "name": "AnalyzeFile",
      "value_schema": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to the file to analyze"
          }
        },
        "additionalProperties": false
      },
      "action": {
        "kind": "Pool",
        "instructions": {"link": "analyze-file.md"}
      },
      "next": ["ProcessRefactorList"]
    },
    {
      "name": "ProcessRefactorList",
      "value_schema": {
        "type": "object",
        "required": ["file", "refactors"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to the file being refactored"
          },
          "refactors": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of refactoring operations to apply"
          }
        },
        "additionalProperties": false
      },
      "action": {
        "kind": "Pool",
        "instructions": {"link": "process-refactor-list.md"}
      },
      "next": ["ProcessRefactorList", "CommitFile"]
    },
    {
      "name": "CommitFile",
      "value_schema": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to the file to commit"
          }
        },
        "additionalProperties": false
      },
      "action": {
        "kind": "Pool",
        "instructions": {"link": "commit-file.md"}
      },
      "next": []
    }
  ]
}
