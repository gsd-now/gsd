digraph GSD {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "Decide" [shape=box, label="Decide", style=filled, fillcolor="#e3f2fd"];
  "PathA" [shape=box, label="PathA", style=filled, fillcolor="#e3f2fd"];
  "PathB" [shape=box, label="PathB", style=filled, fillcolor="#e3f2fd"];
  "Done" [shape=box, peripheries=2, label="Done", style=filled, fillcolor="#e3f2fd"];

  "Decide" -> "PathA";
  "Decide" -> "PathB";
  "PathA" -> "Done";
  "PathB" -> "Done";
}
