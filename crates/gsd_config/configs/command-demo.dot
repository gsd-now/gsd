digraph GSD {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "Split" [shape=diamond, label="Split", style=filled, fillcolor="#fff3e0"];
  "Process" [shape=diamond, label="Process", style=filled, fillcolor="#fff3e0"];
  "Collect" [shape=diamond, peripheries=2, label="Collect", style=filled, fillcolor="#fff3e0"];

  "Split" -> "Process";
  "Process" -> "Collect";
}
