digraph GSD {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "Distribute" [shape=box, label="Distribute", style=filled, fillcolor="#e3f2fd"];
  "Worker" [shape=box, peripheries=2, label="Worker", style=filled, fillcolor="#e3f2fd"];

  "Distribute" -> "Worker";
}
