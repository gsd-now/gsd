digraph GSD {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "Analyze" [shape=box, label="Analyze", style=filled, fillcolor="#e3f2fd"];
  "ProcessRefactorList" [shape=box, label="ProcessRefactorList", style=filled, fillcolor="#e3f2fd"];
  "CommitFile" [shape=box, label="CommitFile", style=filled, fillcolor="#e3f2fd"];
  "VerifyFile" [shape=box, label="VerifyFile", style=filled, fillcolor="#e3f2fd"];
  "Done" [shape=box, peripheries=2, label="Done", style=filled, fillcolor="#e3f2fd"];

  "Analyze" -> "ProcessRefactorList";
  "ProcessRefactorList" -> "ProcessRefactorList";
  "ProcessRefactorList" -> "CommitFile";
  "CommitFile" -> "Analyze";
  "CommitFile" -> "VerifyFile";
  "CommitFile" -> "Done";
  "VerifyFile" -> "ProcessRefactorList";
  "VerifyFile" -> "Done";
}
