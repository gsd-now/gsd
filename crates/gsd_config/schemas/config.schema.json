{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/rbalicki2/gsd/blob/master/crates/gsd_config/schemas/config.schema.json",
  "title": "GSD Config",
  "description": "Configuration for GSD task orchestration state machines",
  "type": "object",
  "additionalProperties": false,
  "required": ["steps"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation"
    },
    "options": {
      "$ref": "#/$defs/Options"
    },
    "steps": {
      "type": "array",
      "description": "Step definitions forming the state machine",
      "items": {
        "$ref": "#/$defs/Step"
      }
    }
  },
  "$defs": {
    "Options": {
      "type": "object",
      "description": "Runtime options for task execution",
      "additionalProperties": false,
      "properties": {
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "description": "Timeout in seconds for each task (omit for no timeout)"
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Maximum retries per task"
        },
        "retry_on_timeout": {
          "type": "boolean",
          "default": true,
          "description": "Whether to retry when agent times out"
        },
        "retry_on_invalid_response": {
          "type": "boolean",
          "default": true,
          "description": "Whether to retry when agent returns invalid response"
        }
      }
    },
    "StepOptions": {
      "type": "object",
      "description": "Per-step options that override global defaults",
      "additionalProperties": false,
      "properties": {
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "description": "Timeout in seconds for this step (overrides global)"
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum retries for this step (overrides global)"
        },
        "retry_on_timeout": {
          "type": "boolean",
          "description": "Whether to retry on timeout for this step (overrides global)"
        },
        "retry_on_invalid_response": {
          "type": "boolean",
          "description": "Whether to retry on invalid response for this step (overrides global)"
        }
      }
    },
    "Step": {
      "type": "object",
      "description": "A step in the state machine",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Step name (e.g., Analyze, Implement)"
        },
        "schema": {
          "$ref": "#/$defs/SchemaRef",
          "description": "JSON Schema for the step's value payload (omit to accept any value)"
        },
        "instructions": {
          "type": "string",
          "default": "",
          "description": "Markdown instructions shown to agents"
        },
        "next": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Valid next step names (empty = terminal step)"
        },
        "options": {
          "$ref": "#/$defs/StepOptions",
          "description": "Per-step options that override global options"
        }
      }
    },
    "SchemaRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "Inline" },
            "value": {
              "type": "object",
              "description": "Inline JSON Schema"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "Link" },
            "value": {
              "type": "string",
              "description": "Path to a JSON Schema file"
            }
          }
        }
      ]
    }
  }
}
